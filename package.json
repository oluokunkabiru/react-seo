{
  "name": "react-seo-kit",
  "version": "1.0.1",
  "description": "React SEO component library for managing meta tags, Open Graph, Twitter Cards, JSON-LD structured data, and canonical URLs per page — enabling Google to detect and index every individual page",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "dev": "tsc -p tsconfig.esm.json --watch"
  },
  "keywords": [
    "react",
    "seo",
    "meta",
    "meta-tags",
    "helmet",
    "react-helmet",
    "open-graph",
    "og-tags",
    "twitter-card",
    "twitter-meta",
    "structured-data",
    "json-ld",
    "schema",
    "schema.org",
    "canonical",
    "canonical-url",
    "robots",
    "google",
    "google-search",
    "search-engine-optimization",
    "page-seo",
    "react-seo",
    "head-manager",
    "document-head",
    "social-preview",
    "link-preview",
    "typescript",
    "koadit"
  ],
  "author": "KOADIT Digital Solutions",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oluokunkabiru/react-seo"
  },
  "bugs": {
    "url": "https://github.com/oluokunkabiru/react-seo/issues"
  },
  "homepage": "https://github.com/oluokunkabiru/react-seo#readme",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "react-helmet-async": "^2.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5"
  }
}
